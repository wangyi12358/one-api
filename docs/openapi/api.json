  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "username": {"type": "string"},
          "display_name": {"type": "string"},
          "role": {"type": "integer", "description": "0=游客, 1=普通用户, 10=管理员, 100=Root"},
          "status": {"type": "integer", "description": "1=启用, 2=禁用, 3=删除"},
          "email": {"type": "string", "format": "email"},
          "github_id": {"type": "string"},
          "wechat_id": {"type": "string"},
          "lark_id": {"type": "string"},
          "oidc_id": {"type": "string"},
          "access_token": {"type": "string"},
          "quota": {"type": "integer", "description": "用户额度"},
          "used_quota": {"type": "integer", "description": "已使用额度"},
          "request_count": {"type": "integer"},
          "group": {"type": "string"},
          "aff_code": {"type": "string", "description": "邀请码"},
          "inviter_id": {"type": "integer"}
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "type": {"type": "integer", "description": "渠道类型"},
          "key": {"type": "string", "description": "API Key"},
          "status": {"type": "integer", "description": "0=未知, 1=启用, 2=手动禁用, 3=自动禁用"},
          "name": {"type": "string"},
          "weight": {"type": "integer"},
          "created_time": {"type": "integer"},
          "test_time": {"type": "integer"},
          "response_time": {"type": "integer", "description": "响应时间(毫秒)"},
          "base_url": {"type": "string"},
          "balance": {"type": "number", "description": "余额(USD)"},
          "balance_updated_time": {"type": "integer"},
          "models": {"type": "string", "description": "支持的模型列表"},
          "group": {"type": "string"},
          "used_quota": {"type": "integer"},
          "model_mapping": {"type": "string", "description": "模型映射"},
          "priority": {"type": "integer"},
          "config": {"type": "string", "description": "渠道配置"},
          "system_prompt": {"type": "string"}
        }
      },
      "ChannelCreate": {
        "type": "object",
        "properties": {
          "type": {"type": "integer"},
          "key": {"type": "string"},
          "name": {"type": "string"},
          "base_url": {"type": "string"},
          "models": {"type": "string"},
          "group": {"type": "string"},
          "model_mapping": {"type": "string"},
          "priority": {"type": "integer"},
          "config": {"type": "string"}
        },
        "required": ["type", "key", "name", "models"]
      },
      "Token": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "user_id": {"type": "integer"},
          "key": {"type": "string", "description": "令牌 Key"},
          "status": {"type": "integer", "description": "1=启用, 2=禁用, 3=过期, 4=用尽"},
          "name": {"type": "string"},
          "created_time": {"type": "integer"},
          "accessed_time": {"type": "integer"},
          "expired_time": {"type": "integer", "description": "过期时间戳，-1表示永不过期"},
          "remain_quota": {"type": "integer"},
          "unlimited_quota": {"type": "boolean"},
          "used_quota": {"type": "integer"},
          "models": {"type": "string", "description": "允许的模型"},
          "subnet": {"type": "string", "description": "允许的子网"}
        }
      },
      "Redemption": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "user_id": {"type": "integer"},
          "key": {"type": "string", "description": "兑换码"},
          "status": {"type": "integer", "description": "1=未使用, 2=已使用, 3=已禁用"},
          "name": {"type": "string"},
          "created_time": {"type": "integer"},
          "used_time": {"type": "integer"},
          "quota": {"type": "integer", "description": "兑换额度"}
        }
      }
    },
    "securitySchemes": {
      "UserAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "用户认证令牌，格式: Bearer <session_token>"
      },
      "AdminAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "管理员认证令牌，格式: Bearer <session_token>"
      },
      "RootAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Root 用户认证令牌，格式: Bearer <session_token>"
      }
    }
  }
}