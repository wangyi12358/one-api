  },
  "tags": [
    {"name": "获取模型列表"},
    {"name": "Chat Completions"},
    {"name": "Completions"},
    {"name": "图片生成"},
    {"name": "Embeddings"},
    {"name": "音频"},
    {"name": "Moderations"},
