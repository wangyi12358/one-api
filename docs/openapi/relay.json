    "/v1/audio/transcriptions": {
      "post": {
        "summary": "音频转文字",
        "description": "将音频转换为文字，兼容 OpenAI Audio Transcriptions API",
        "operationId": "createTranscription",
        "tags": ["音频"],
        "security": [{"ApiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "音频文件"
                  },
                  "model": {
                    "type": "string",
                    "description": "模型 ID，如 whisper-1"
                  },
                  "language": {
                    "type": "string",
                    "description": "音频语言，ISO-639-1 格式"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "提示词"
                  },
                  "response_format": {
                    "type": "string",
                    "enum": ["json", "text", "srt", "verbose_json", "vtt"],
                    "default": "json"
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "default": 0
                  }
                },
                "required": ["file", "model"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/audio/translations": {
      "post": {
        "summary": "音频翻译",
        "description": "将音频翻译为英文，兼容 OpenAI Audio Translations API",
        "operationId": "createTranslation",
        "tags": ["音频"],
        "security": [{"ApiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "model": {
                    "type": "string",
                    "default": "whisper-1"
                  },
                  "prompt": {"type": "string"},
                  "response_format": {
                    "type": "string",
                    "enum": ["json", "text", "srt", "verbose_json", "vtt"],
                    "default": "json"
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "default": 0
                  }
                },
                "required": ["file", "model"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/v1/audio/speech": {
      "post": {
        "summary": "文字转语音",
        "description": "将文字转换为语音，兼容 OpenAI Audio Speech API",
        "operationId": "createSpeech",
        "tags": ["音频"],
        "security": [{"ApiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "description": "模型 ID，如 tts-1"
                  },
                  "input": {
                    "type": "string",
                    "description": "要转换的文字"
                  },
                  "voice": {
                    "type": "string",
                    "enum": ["alloy", "echo", "fable", "onyx", "nova", "shimmer"],
                    "description": "语音类型"
                  },
                  "response_format": {
                    "type": "string",
                    "enum": ["mp3", "opus", "aac", "flac", "wav", "pcm"],
                    "default": "mp3"
                  },
                  "speed": {
                    "type": "number",
                    "minimum": 0.25,
                    "maximum": 4.0,
                    "default": 1.0
                  }
                },
                "required": ["model", "input", "voice"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "audio/mpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/v1/moderations": {
      "post": {
        "summary": "内容审核",
        "description": "检查内容是否包含有害信息，兼容 OpenAI Moderations API",
        "operationId": "createModeration",
        "tags": ["Moderations"],
        "security": [{"ApiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "input": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "array", "items": {"type": "string"}}
                    ],
                    "description": "要审核的内容"
                  },
                  "model": {
                    "type": "string",
                    "default": "text-moderation-latest"
                  }
                },
                "required": ["input"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
